# Give each app a flat node_modules tree (like npm/yarn classic) so Metro's
# resolver walks only within the app's own dependency graph. Fixes the
# desktop (expo 54 / RN 0.81) vs mobile (expo 55 / RN 0.83) version leak
# that happened with the default pnpm symlink layout.
node-linker=hoisted

# Keep the install deterministic across machines
strict-peer-dependencies=false
auto-install-peers=true
